<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f9f9f9;
        }

        .invoice-container {
            height: 29.7cm;
            width: 21cm;
            background-color: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
        }

        .header {
            background-color: #1b3f6d;
            color: white;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-left {
            display: flex;
            flex-direction: column;
        }

        .header-left img {
            width: 120px;
            margin-bottom: 70px;
        }

        .header-left p {
            font-size: 16px;
            font-weight: 600;
            margin-top: 10px;
        }

        .header-right {
            text-align: right;
            line-height: 1.7;
        }

        .header-right p {
            font-size: 12px;
            margin: 2px 0;
        }

        .header-right p:first-child {
            font-size: 14px;
            font-weight: 600;
        }

        .table-container {
            padding: 0 20px;
            flex: 1;
            min-height: 12cm;
            max-height: 12cm;
            position: relative;
            margin: 10px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th,
        table td {
            padding: 12px;
            border: 1px solid #ddd;
            font-size: 14px;
            font-weight: 300;
        }

        table th {
            font-weight: bold;
            background-color: #1b3f6d;
            color: #fff;
            text-align: center;
        }

        table td {
            text-align: left;
        }

        table td:first-child,
        table td:nth-child(3),
        table td:nth-child(4) {
            text-align: center;
        }

        .totals-container {
            padding: 20px;
            background-color: white;
            flex-grow: 1;
            line-height: 2.2;
        }

        .amount-calc {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            font-size: 14px;
        }

        .totals {
            display: flex;
            justify-content: space-between;
            font-size: 16px;
            font-weight: bold;
            border-top: 1px solid #ccc;
            padding-top: 10px;
        }

        .fixed-bottom {
            position: relative;
            margin-top: auto;
            width: 100%;
        }

        .delivery-type {
            background-color: #e8ecf0;
            padding: 8px;
            font-size: 12px;
            font-weight: 400;
        }

        .footer {
            background-color: #1b3f6d;
            height: 23px;
            color: #fff;
            text-align: center;
            font-size: 12px;
            line-height: 20px;
        }

        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 15px 20px;
            margin-top: 10px;
        }

        .details-box {
            width: 48%;
            display: flex;
            flex-direction: column;
        }

        .patient-details, .invoice-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 15px;
            background-color: #F3F9FF;
            border-radius: 5px;
            flex-grow: 1;
            font-size: 12px;
        }

        .details-heading {
            font-size: 13px;
            font-weight: 400;
            margin-bottom: 5px;
            color: #242424;
            padding-left: 10px;
            padding-top: 5px;
        }

        .patient-details p, .invoice-details p {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin: 5px 0;
        }

        .patient-details strong, .invoice-details strong {
            min-width: 140px;
            text-align: left;
            font-weight: 500;
        }

        .patient-details span, .invoice-details span {
            flex-grow: 1;
            text-align: left;
            color: #1B3F6D;
        }

        @media print {
            .invoice-container {
                page-break-after: always;
            }
        }
    </style>
</head>

<body>
    <% 
    const items = scans || [];
    let currentPage = 1;
    let itemsProcessed = 0;
    let availableHeight = 500.54; // Base available height for table
    
    // Calculate address height impact once before the loop
    const addressParts = [
        patient?.address_line_1,
        patient?.address_line_2,
        patient?.city,
        patient?.postal_code,
        patient?.country
    ].filter(Boolean);

    const fullAddress = addressParts.join(', ');
    if (fullAddress.length > 72) {
        const dividedValue = Math.floor(fullAddress.length / 36);
        availableHeight -= (12 * dividedValue) + 10; // 10px is bottom margin of availableHeight
    }
    
    // Loop through pages using while loop for dynamic pagination
    while (itemsProcessed < items.length) {
    %>
    <div class="invoice-container">
        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                <img src="https://d2pznqasld4zpy.cloudfront.net/common/WebLogo.svg" alt="SendScript">
                <p>Invoice</p>
            </div>
            <div class="header-right">
                <p><%= patient.site_name %></p>
                <p>
                    <%= [
                      patient.site_address_line_1,
                      patient.site_address_line_2,
                      patient.site_address_line_3,
                      patient.site_city,
                      patient.site_county,
                      patient.site_country
                    ].filter(Boolean).join(', ') %>
                </p>
                <p><%= patient.site_postal_code %></p>
                <p>Tel: <%= patient.site_contact_number %></p>
                <p>Email: <%= patient.site_email %></p>
            </div>
        </div>

        <div class="details-container">
            <div class="details-box">
                <div class="details-heading">Patient Details</div>
                <div class="patient-details">
                    <p>
                        <strong>Full Name:</strong>
                        <span><%= patient.patient_name %></span>
                    </p>
                    <p>
                        <strong>Date Of Birth:</strong>
                        <span>
                          <%= patient.dob %>
                        </span>
                        <span>
                            <span style="color:#000;font-weight:500;margin-left:10px;">Age:</span>
                            <span><%= patient.patient_age %></span>
                        </span>
                    </p>
                    <p style="line-height: 16px;">
                        <strong>Address:</strong>
                        <span>
                          <%= (
                            [patient?.address_line_1, patient?.address_line_2, patient?.city, patient?.country, patient?.postal_code]
                              .filter(v => v && v.trim())
                              .join(', ')
                          ) || '-' %>
                        </span>
                      </p>
                      
                      <p>
                        <strong>Contact Number:</strong>
                        <span><%= patient?.country_code %> <%= patient?.mobile?.trim() || '-' %></span>
                    </p>
                </div>
            </div>

            <div class="details-box">
                <div class="details-heading">Invoice Details</div>
                <div class="invoice-details">
                    <p>
                        <strong>Invoice Number:</strong>
                        <span><%= invoice_number %></span>
                    </p>
                    <p>
                        <strong>Invoice Date:</strong>
                        <span>
                          <%= invoice_date %>
                        </span>
                    </p>
                </div>
            </div>
        </div>

        <div class="table-container" style="min-height: 364px;" data-min-height="<%= Math.round(availableHeight) %>">
            <table>
                <thead>
                    <tr>
                        <th>SL No</th>
                        <th>Scan</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <% let itemsInThisPage = 0; %>
                    <%
                        let currentHeight = 0;
                        let actualIsLastPage = false;
                    %>
                    <% for (let i = itemsProcessed; i < items.length; i++) { %>
                        <% 
                            // Estimate if this row will fit
                            const item = items[i];
                            let estimatedHeight = 44; // base height

                            // Estimate the height based on scan name + body part length
                            const scanNameText = `${item.scan_name || ''}${item.body_part ? ' - ' + item.body_part : ''}`;
                            if (scanNameText.length > 197) {
                                estimatedHeight += 48;
                            } else if (scanNameText.length > 131) {
                                estimatedHeight += 24;
                            } else if (scanNameText.length > 65) {
                                estimatedHeight += 12;
                            }

                            // Break if adding this row would exceed available height, but only if we already have at least one row in the current page
                            if (currentHeight + estimatedHeight > availableHeight && itemsInThisPage > 0) {
                                break;
                            }

                            currentHeight += estimatedHeight;
                        %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= item.scan_name %><%= item.body_part ? ' - ' + item.body_part : '' %></td>
                            <td style="text-align: right; align-items: right;">£ <%= item.out_patient_price %></td>
                        </tr>
                        <% 
                            itemsInThisPage++;
                            itemsProcessed++;
                            // Check if this is the last item overall
                            if (i === items.length - 1) {
                                actualIsLastPage = true;
                            }
                        %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (actualIsLastPage) { %>
        <div class="totals-container">
            <div class="amount-calc">
                <div>Gross Amount</div>
                <div>£ <%= Number(grossAmount).toFixed(2) %></div>
            </div>
            <div class="amount-calc">
                <div>Discount</div>
                <div>( - ) £ <%= Number(commissionValue || 0).toFixed(2) %></div>
            </div>
            <div class="totals">
                <div>Net Amount</div>
                <div>£ <%= Number(netAmount || 0).toFixed(2) %></div>
            </div>
        </div>
        <% } else { %>
        <div class="totals-container"></div>
        <% } %>

        <div class="footer"></div>
    </div>
    <% 
        currentPage++;
    } %>
    <script>
        document.querySelectorAll('.table-container').forEach(container => {
            const minHeight = container.getAttribute('data-min-height');
            if (minHeight) {
                container.style.minHeight = minHeight + 'px';
            }
        });
    </script>
</body>

</html>