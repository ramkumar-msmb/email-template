<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prescription Details</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            background-color: #f5f5f5;
            margin: 0;
            padding: 0;
        }

        .pdf-container {
            width: 21cm;
            height: 29.7cm;
            background-color: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .header {
            color: #222;
            border-bottom: 1px solid #D9D9D9;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 18px;
        }

        .header-left {
            display: flex;
            flex-direction: column;
        }

        .header img {
            width: 120px;
        }
        .header-line{
            height: 1px;
            width: 20cm;
            padding: 0px 18px;
            margin: 0px 18px 10px 18px;
            background-color: #D9D9D9;
        }

        .header-title {
            font-size: 16px;
            font-weight: 600;
            margin-top: 8px;
        }

        .clinic-details {
            text-align: right;
            line-height: 1.4;
        }

        .clinic-details p {
            font-size: 10px;
            margin: 2px 0;
        }
        .clinic-details strong {
            font-size: 15px;
            margin: 2px 0;
        }


        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
            padding-top: 2px;
            align-items: stretch;
            gap: 12px;
        }

        .details-box {
            width: 50%;
            display: flex;
            flex-direction: column;
            font-size: 12px;
        }
        .details-box .comments{
            font-size: 9px;
            font-weight: 400;
            color: #444;
        }

        .patient-details,
        .appointment-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }


        .details-heading {
            font-size: 9px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #222;
        }



        .patient-details p,
        .appointment-details p {
            display: flex;
            justify-content: space-between;
            gap: 10px;
        }


        .patient-details strong,
        .appointment-details strong,
        .age {
            text-align: left;
            font-weight: 400;
            font-size: 9px;
            color: #444;
        }


        .patient-details span,
        .appointment-details span,
        .age-value {
            flex-grow: 1;
            text-align: left;
            font-size: 9px;
            color: #222;
        }


        .dob-age {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }

        .prescription-table-container {
            margin: 10px 18px;
            margin-top: 2px;
            overflow: hidden;
            border-radius: 10px;
            border: 0.5px solid #CBE3E3;
            flex: 1;
            min-height: 12cm;
            max-height: 100%;
            position: relative;
        }

        .prescription-table-container::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url("/src/assets/common/Prescription Table.svg");
            background-repeat: no-repeat;
            background-position: center;
            background-size: contain;
            opacity: 0.9;
            z-index: -1;
        }

        .prescription-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            border: 0;
        }

        .prescription-table thead,
        .prescription-table tr {
            border: 0;
        }

        .prescription-table th,
        .prescription-table td {
            font-size: 9px;
            padding: 10px;
            text-align: left;
            vertical-align: top;
            border: 0;
            word-break: break-word;
        }

        .prescription-table th {
            font-weight: 500;
            color: #444;
            height: 30px;
            font-size: 9px;
        }
        .prescription-table th{
            border-bottom: 1px solid #d9d9d9;
        }

        .prescription-table th:nth-child(1),
        .prescription-table td:nth-child(1) {
            width: 8%;
        }

        .prescription-table th:nth-child(2),
        .prescription-table td:nth-child(2) {
            width: 48%;
        }

        .prescription-table th:nth-child(3),
        .prescription-table td:nth-child(3) {
            width: 14%;
        }

        .prescription-table th:nth-child(4),
        .prescription-table td:nth-child(4) {
            width: 14%;
        }

        .prescription-table th:nth-child(5),
        .prescription-table td:nth-child(5) {
            width: 10%;
        }

        .medicine-details {
            display: flex;
            flex-direction: column;
            font-size: 10px;
            max-height: 120px;
        }

        .medicine-instruction {
            font-size: 9px;
            color: #1B3F6D;
        }

        .prescribed-by {
            padding: 12px 18px;
            padding-top: 0px;
        }
        

        .prescribed-by-title {
            font-size: 8px;
            font-weight: 400;
            margin-bottom: 5px;
            color: #222;
        }
        .prescription-info-container{
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
        }
        .prescription-info-container .px-meta-data-right p,
        .prescription-info-container .px-meta-data-left p{
            font-size: 10px;
            color: #444;
        }
        .prescription-info-container .px-meta-data-right p strong,
        .prescription-info-container .px-meta-data-left p strong{
            font-size: 10px;
            color: #222;
        }


        .doctor-details {
            display: flex;
            justify-content: space-between;
            margin-top: 10px;
            padding: 8px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }

        .doctor-details table {
            width: 100%;
            font-size: 9px;
            border-collapse: collapse;
        }

        .doctor-details table th,
        .doctor-details table td {
            padding: 2px;
            text-align: left;
            vertical-align: top;
            word-wrap: break-word;
        }

        .doctor-details table td {
            color: #222;
            font-weight: 600;
        }

        .doctor-details table th {
            width: 25%;
            color: #444;
            font-weight: normal;
        }

        .qr-signature-container {
            display: flex;
            padding: 0 18px;
            padding-bottom: 18px;
        }

        .qr-container {
            width: 45px;
            height: 100%;
            flex-shrink: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        .qr-container .qr-content {
            width: 35px;
            height: 38px;

        }
        .qr-container img {
            width: 100%;
        }

        .qr-container p {
            margin-top: 3px;
            font-size: 5px;
            white-space: nowrap;
        }

        .signature-section {
            font-size: 6.05px;
            color: #222;
        }

        .signature-section p {
            margin: 5px 0;
            line-height: 1.5;
        }
        .signature-section p:first-child{
            margin-top: 0;
        }
        .signature-section p:last-child{
            margin-bottom: 0;
        }


        .medicine-name {
            display: block;
            line-height: 1.4;
            white-space: normal;
            overflow: visible;
            margin-bottom: 4px;
            font-size: 9px;
        }

        .truncate-text {
            max-height: none;
            /* Allow text to expand fully */
            overflow: visible;
            word-break: break-word;
        }

        /* Page break styles */
        .page-break {
            page-break-before: always;
            break-before: page;
        }

        .page {
            width: 21cm;
            height: 29.7cm;
            background-color: white;
            margin: 0 auto;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Ensure tables break properly */
        table {
            page-break-inside: auto;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        thead {
            display: table-header-group;
        }

        tfoot {
            display: table-footer-group;
        }
    </style>
</head>

<body>


        <% let currentPage = 1; %>
        <% let itemsProcessed = 0; %>
        <% let availableHeight = 363.54; %>
        
        <% 
            // Calculate address height impact once before the loop
            const addressParts = [
                patient_details?.patient_address_line_1,
                patient_details?.patient_address_line_2,
                patient_details?.patient_city,
                patient_details?.patient_postal_code,
                patient_details?.patient_country
            ].filter(Boolean);

            const fullAddress = addressParts.join(', ');
            console.log('fullAddress.length:', fullAddress.length);
            console.log('availableHeight before:', availableHeight);
            if (fullAddress.length > 72) {
                const dividedValue = Math.floor(fullAddress.length / 36);
                availableHeight -= (12 * dividedValue) + 10; // 10px is bottom margin of availableHeight
            }
            console.log('availableHeight after:', availableHeight);
        %>
        
        <% while (itemsProcessed < prescription_items.length) { %>
            <div class="page <%= currentPage > 1 ? 'page-break' : '' %>">
                <div class="header">
                    <div class="header-left">
                        <img src="https://d2pznqasld4zpy.cloudfront.net/common/logo.svg" alt="SendScript">
                    </div>

                    <div class="clinic-details">
                        <p><strong>PRIVATE PRESCRIPTION</strong></p>
                        <p>Powered by SendScript</p>
                    </div>
                </div>
                <div class="prescription-info-container">
                    <div class="px-meta-data-right">
                        <p>Prescription ID: <strong><%= prescription.booking_code %></strong></p>
                        <p>Date: <strong><%= prescription.prescription_date %></strong></p>
                    </div>
                    <div class="px-meta-data-left">
                        <p>Prescription Type: <strong>
                                <%= prescription_type %>
                            </strong></p>
                    </div>
                </div>
                <div class="header-line"></div>
                <div class="details-container">
                    <div class="details-box">
                        <div class="details-heading">Patient Details</div>
                        <div class="patient-details">
                            <p><strong>Full Name:</strong> <span>
                                    <%= patient_details?.patient_title %>
                                    <%= patient_details?.patient_first_name %>
                                    <%= patient_details?.patient_sur_name %>
                                </span>
                            </p>
                            <p class="dob-age">
                                <strong>DOB:</strong> <span>
                                    <%= new Date(new Date(patient_details?.patient_dob).setDate(new
                                        Date(patient_details?.patient_dob).getDate())).toLocaleDateString('en-GB')
                                        %>
                                        <span class="age" style="color: #444; font-weight: 500; margin-left: 10px;"> Age:
                                        </span>
                                        <span class="age-value">
                                            <%= patient_age %>
                                        </span>
                                        <span class="age" style="color: #444; font-weight: 500; margin-left: 10px;"> Gender:
                                        </span>
                                        <span class="age-value">
                                            <%= patient_gender %>
                                        </span>
                                </span>
                            </p>
                            <p><strong >Address:</strong>
                                <span>
                                    <%= [
                                        patient_details?.patient_address_line_1,
                                        patient_details?.patient_address_line_2,
                                        patient_details?.patient_city,
                                        patient_details?.patient_postal_code
                                    ].filter(Boolean).join(', ') %>
                                    <br>
                                    <%= patient_details?.patient_country %>
                                </span>
                            </p>
                            <p><strong>Mobile Number:</strong> <span>
                                <%= patient_details?.patient_country_code %> <%= patient_details?.patient_mobile %>
                                </span></p>
                        </div>
                    </div>

                    <div class="details-box">
                        <div class="details-heading">Clinic Information</div>
                        <div class="appointment-details">
                            <p><strong style="min-width: 59px;">Clinic Name:</strong>
                                <span>
                                    <%= prescription.clinic_name %>
                                </span>
                            </p>
                            <p><strong style="min-width: 59px;">Clinic Address:</strong> 
                                <span>
                                     <%= [
                                        prescription?.clinic_address_line_1,
                                        prescription?.clinic_address_line_2,
                                        prescription?.clinic_city,
                                        prescription?.clinic_postal_code
                                    ].filter(Boolean).join(', ') %>
                                    <br>
                                    <%= prescription?.clinic_country %>
                                </span>
                            </p>
                            <p><strong style="min-width: 59px;">Email Address:</strong> 
                                <span>
                                    <%= prescription.clinic_email %>
                                </span>
                            </p>
                            <p><strong style="min-width: 59px;">Telephone:</strong> 
                                <span>
                                    <%= prescription.clinic_contact_number %>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="prescription-table-container" style="min-height: 364px;" data-min-height="<%= Math.round(availableHeight) %>">
                    <table class="prescription-table">
                        <thead>
                            <tr>
                                <th>SL No</th>
                                <th>Medicine</th>
                                <th>Duration</th>
                                <th>Method</th>
                                <th>Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% let itemsInThisPage = 0; %>
                            <%
                                let currentHeight = 0;
                            %>
                            <% for (let i = itemsProcessed; i < prescription_items.length; i++) { %>
                                <% 
                                    // Estimate if this row will fit
                                    const item = prescription_items[i];
                                    let estimatedHeight = 44; // base height

                                    // Estimate the height of the unit

                                    if(item.unit && item.unit.length > 45) {
                                        estimatedHeight += 96;
                                    }else if(item.unit && item.unit.length > 36) {
                                        estimatedHeight += 48;
                                    }else if(item.unit && item.unit.length > 27) {
                                        estimatedHeight += 24;
                                    }else if(item.unit && item.unit.length > 18) {
                                        estimatedHeight += 12;
                                    }else if (item.name && item.name.length > 197) {
                                        estimatedHeight += 48;
                                    }else if (item.name && item.name.length > 131) {
                                        estimatedHeight += 24;
                                    } else if (item.name && item.name.length > 65) {
                                        estimatedHeight += 12;
                                    }

                                    if (item.dosage_note) {
                                        const dosageNoteLength = item.dosage_note.length;
                                        if (dosageNoteLength > 197) {
                                            estimatedHeight += 48;
                                        }else if (dosageNoteLength > 131) {
                                            estimatedHeight += 24;
                                        } else if (dosageNoteLength > 65) {
                                            estimatedHeight += 12;
                                        }
                                    }

                                    // Break if adding this row would exceed available height, but only if we already have at least one row in the current page
                                    if (currentHeight + estimatedHeight > availableHeight && itemsInThisPage > 0) {
                                        break;
                                    }

                                    currentHeight += estimatedHeight;
                                %>
                                <tr>
                                    <td><%= item.slNo %></td>
                                    <td>
                                        <div class="medicine-details">
                                            <span class="medicine-name truncate-text"><%= item.name %></span>
                                            <span class="medicine-instruction">- <%= item.dosage_note %></span>
                                        </div>
                                    </td>
                                    <td>
                                        <%= item.duration %> <%= item.duration_type %>
                                    </td>
                                    <td><%= item.method %></td>
                                    <td>
                                        <%= item.quantity %> <%= item.unit %>
                                    </td>
                                </tr>
                                <% 
                                    itemsInThisPage++;
                                    itemsProcessed++;
                                %>
                            <% } %>
                        </tbody>
                    </table>
                </div>


                <div class="details-container">
                    <div class="details-box">
                        <div class="details-heading">Comments To Patient</div>
                        <div class="comments patient-details">
                            <p><%= patient_details?.comment_to_patient %></p>
                        </div>
                    </div>

                    <div class="details-box">
                        <div class="details-heading">Comments To Pharmacy</div>
                        <div class="comments patient-details">
                            <p><%= patient_details?.comment_to_pharmacy %></p>
                        </div>
                    </div>
                </div>

                <div class="prescribed-by">
                    <div class="prescribed-by-title">Prescribed By</div>
                    <div class="doctor-details">
                        <table>
                            <tr>
                                <th>Name:</th>
                                <th>Registration No:</th>
                                <th>Qualifications:</th>
                            </tr>
                            <tr>
                                <td>
                                    <%= prescription.doctor_title %>
                                    <%= prescription.doctor_first_name %>
                                    <%= prescription.doctor_sur_name %>
                                </td>
                                <td>GMC - <%= prescription.doctor_gmc_number %>
                                </td>
                                <td>
                                    <%= prescription.doctor_qualification.replace(/,/g, ', ' ) %>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="qr-signature-container">
                    <div class="qr-container">
                        <div class="qr-content">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://sendscript.com/dispense"
                                alt="QR Code">
                            </div>
                            <p>Scan to Dispense</p>
                    </div>
                    <div class="signature-section">
                        <p>This prescription has been signed using an advanced electronic signature</p>
                        <p>E-signature:<strong> <%= prescription.doctor_signature %></strong>
                        </p>
                        <p>
                            Date and Time of signature:
                            <strong>
                            <%= new Date(prescription_created_at).toLocaleString('en-GB', { 
                                  day: '2-digit',
                                  month: '2-digit',
                                  year: 'numeric',
                                  hour: '2-digit',
                                  minute: '2-digit',
                                  hour12: true,
                                  timeZone: 'UTC'   // 👈 prevents shifting to server timezone
                            }).replace('AM', 'am').replace('PM', 'pm') %>
                            </strong>
                        </p>                  
                        <p>To verify (or) dispense the prescription visit: <strong>
                            www.sendscript.com/dispense
                        </strong></p>
                    </div>
                </div>
            </div>
            <% currentPage++; %>
        <% } %>
    <script>
        document.querySelectorAll('.prescription-table-container').forEach(container => {
            const minHeight = container.getAttribute('data-min-height');
            if (minHeight) {
                container.style.minHeight = minHeight + 'px';
            }
        });
    </script>
</body>

</html>