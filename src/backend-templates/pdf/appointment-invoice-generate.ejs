<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f9f9f9;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        .invoice-container {
            height: 29.7cm;
            width: 21cm;
            background-color: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
        }

        .header {
            color: white;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
         .header {
            color: #222;
            border-bottom: 1px solid #D9D9D9;
        }

        .header-left {
            display: flex;
            flex-direction: column;
        }

        .header-left img {
            width: 120px;
        }

        .header-left p {
            font-size: 16px;
            font-weight: 600;
            margin-top: 10px;
        }

        .header-right {
            text-align: right;
            line-height: 1.7;
        }

        .header-right p {
        }

        .header-line{
            height: 1px;
            width: 20cm;
            padding: 0px 18px;
            margin: 0px 18px 10px 18px;
            background-color: #D9D9D9;
        }

        .clinic-details {
            text-align: right;
            line-height: 1.4;
        }

        .clinic-details p {
            font-size: 10px;
            margin: 2px 0;
        }
        .clinic-details strong {
            font-size: 15px;
            margin: 2px 0;
        }

        .prescription-info-container{
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
        }
        .prescription-info-container .px-meta-data-right p,
        .prescription-info-container .px-meta-data-left p{
            font-size: 10px;
            color: #444;
        }
        .prescription-info-container .px-meta-data-right p strong,
        .prescription-info-container .px-meta-data-left p strong{
            font-size: 10px;
            color: #222;
        }

        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
            padding-top: 2px;
            align-items: stretch;
            gap: 12px;
        }

        .details-box {
            width: 50%;
            display: flex;
            flex-direction: column;
            font-size: 12px;
        }

        .patient-details,
        .appointment-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }

        .details-heading {
            font-size: 9px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #222;
        }

        .patient-details p,
        .appointment-details p {
            display: flex;
            justify-content: space-between;
            gap: 5px;
            margin-block: 0px;
        }

        .patient-details strong,
        .appointment-details strong,
        .age {
            text-align: left;
            font-weight: 400;
            font-size: 9px;
            color: #444;
        }

        .patient-details span,
        .appointment-details span,
        .age-value {
            flex-grow: 1;
            text-align: left;
            font-size: 9px;
            color: #222;
        }
        .age-value {
            margin-left: 5px;
        }

        .dob-age {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }

        .table-container {
            margin: 10px 18px;
            margin-top: 2px;
            overflow: hidden;
            border-radius: 10px;
            border: 0.5px solid #CBE3E3;
            flex: 1;
            min-height: 12cm;
            max-height: 100%;
            position: relative;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            border: 0;
        }

        table thead,
        table tr {
            border: 0;
        }

        table th,
        table td {
            font-size: 9px;
            padding: 10px;
            text-align: left;
            vertical-align: top;
            border: 0;
            word-break: break-word;
        }

        table td {
            padding-bottom: 5px;
            padding-top: 5px;
        }
        table tr:first-child td {
            padding-top: 10px;
        }
        table tr:last-child td {
            padding-bottom: 10px;
        }

        table th {
            font-weight: 500;
            color: #444;
            height: 30px;
            font-size: 9px;
            border-bottom: 1px solid #d9d9d9;
        }

        table th:nth-child(1),
        table td:nth-child(1) {
            width: 10%;
        }

        table th:nth-child(2),
        table td:nth-child(2) {
            width: 45%;
        }

        table th:nth-child(3),
        table td:nth-child(3) {
            width: 45%;
            text-align: right;
        }

        .totals-container {
            padding: 15px 18px;
            background-color: white;
            line-height: 2.2;
            font-size: 9px;
        }

        .amount-calc {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            color: #444;
            font-size: 9px;
        }

        .totals {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            font-weight: 600;
            border-top: 1px solid #d9d9d9;
            padding-top: 10px;
            color: #222;
        }

        @media print {
            .invoice-container {
                page-break-after: always;
            }
        }
    </style>
</head>

<body>
    <% const items=prescription_items || []; // Calculate total pages needed const itemsPerPage=10; const
        totalPages=Math.ceil(items.length / itemsPerPage); // Loop through pages for (let page=0; page < totalPages;
        page++) { const startIndex=page * itemsPerPage; const endIndex=Math.min(startIndex + itemsPerPage,
        items.length); const pageItems=items.slice(startIndex, endIndex); const isLastPage=page===totalPages - 1; %>
        <div class="invoice-container">
            <!-- HEADER -->
            <div class="header">
                <div class="header-left">
                    <img src="<%= logo_url %>" alt="SendScript">
                </div>
                <div class="clinic-details">
                    <p><strong>INVOICE</strong></p>
                    <p>Powered by SendScript</p>
                </div>
            </div>

            <div class="prescription-info-container">
                <div class="px-meta-data-right">
                    <p>Invoice Number: <strong><%= invoice_id %></strong></p>
                    <p>Invoice Date: <strong><% 
                        // Parse the ISO date string
                        const dobOriginal_invoice = new Date(invoice_date);
                        
                        // Create a new date object with the date incremented by 1
                        const dob_invoice = new Date(dobOriginal_invoice);
                        dob_invoice.setDate(dobOriginal_invoice.getDate());
                        
                        // Format as DD/MM/YYYY
                        const day_invoice = String(dob_invoice.getDate()).padStart(2, '0');
                        const month_invoice=String(dob_invoice.getMonth() + 1).padStart(2, '0');
                        const year_invoice=dob_invoice.getFullYear();
                        const formattedDate_invoice=`${day_invoice}/${month_invoice}/${year_invoice}`; %>
                        <%= formattedDate_invoice %>
                    </strong></p>
                </div>
                <div class="px-meta-data-left">
                    <p>Booking Date: <strong><%= booking_date %></strong></p>
                    <p>Booking Time: <strong><%= booking_time %></strong></p>
                </div>
            </div>
            <div class="header-line"></div>

            <!-- Patient Details and Pharmacy Details -->
            <div class="details-container">
                <!-- Patient Details -->
                <div class="details-box">
                    <div class="details-heading">Patient Details</div>
                    <div class="patient-details">
                        <p>
                            <strong>Full Name:</strong>
                            <span><%= patient_details.patient_title %> <%= patient_details.patient_first_name %> <%= patient_details.patient_sur_name %></span>
                        </p>
                        <p class="dob-age">
                            <strong>DOB:</strong>
                            <span><% 
                                // Parse the ISO date string
                                const dobOriginal = new Date(patient_details.patient_dob);
                                
                                // Create a new date object with the date incremented by 1
                                const dob = new Date(dobOriginal);
                                dob.setDate(dobOriginal.getDate());
                                
                                // Format as DD/MM/YYYY
                                const day = String(dob.getDate()).padStart(2, '0');
                                const month=String(dob.getMonth() + 1).padStart(2, '0');
                                const year=dob.getFullYear();
                                const formattedDate=`${day}/${month}/${year}`; %>
                                <%= formattedDate %>
                                <span class="age" style="color: #444; font-weight: 500; margin-left: 10px;"> Age: </span>
                                <span class="age-value">
                                    <%= patient_age %>
                                </span>
                            </span>
                        </p>
                        <p>
                            <strong>Address:</strong>
                            <span>
                                <%= [ patient_details?.patient_address_line_1, patient_details?.patient_address_line_2,
                                    patient_details?.patient_city, patient_details?.patient_country,
                                    patient_details?.patient_postal_code ].filter(Boolean).join(', ') %>
                            </span>                          
                        </p>
                        <p>
                            <strong>Contact Number:</strong>
                            <span><%= patient_details.patient_mobile %></span>
                        </p>
                    </div>
                </div>
            
                <!-- Pharmacy Details -->
                <div class="details-box">
                    <div class="details-heading">Pharmacy Information</div>
                    <div class="appointment-details">
                        <p><strong style="min-width: 59px;">Pharmacy Name:</strong>
                            <span>
                                <%= pharmacy.name %>
                            </span>
                        </p>
                        <p><strong style="min-width: 59px;">Pharmacy Address:</strong> 
                            <span>
                                <%= [ pharmacy.address_line_1, pharmacy.address_line_2, pharmacy.address_line_3, pharmacy.city,
                                    pharmacy.county, pharmacy.country ].filter(Boolean).join(', ') %>
                            </span>
                        </p>
                        <p><strong style="min-width: 59px;">Email Address:</strong> 
                            <span>
                                <%= pharmacy.email %>
                            </span>
                        </p>
                        <p><strong style="min-width: 59px;">Telephone:</strong> 
                            <span>
                                <%= pharmacy.contact_number %>
                            </span>
                        </p>
                        <p><strong style="min-width: 59px;">Postal Code:</strong> 
                            <span>
                                <%= pharmacy.postal_code %>
                            </span>
                        </p>
                    </div>
                </div>
            </div>


        <!-- TABLE -->
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>SL No</th>
                        <th>Scan</th>
                        <th style="text-align: right;">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let i=0; i < pageItems.length; i++) { const item=pageItems[i]; const itemNumber=startIndex +
                        i + 1; // Global item number %>
                        <tr>
                            <td>
                                <%= itemNumber %>
                            </td>
                            <td>
                                <%= item.scan_name %>
                            </td>
                            <td style="text-align: right; align-items: right;">£ <%= item.price %>
                            </td>
                        </tr>
                        <% } %>
                </tbody>
            </table>
        </div>

        <!-- TOTALS SECTION - Only show on the last page -->
        <% if (isLastPage) { %>
            <div class="totals-container">
                <div class="amount-calc">
                    <div>Gross Amount</div>
                    <div>£ <%= (total_price - (delivery_charge || 0)).toFixed(2) %>
                    </div>
                </div>
                <div class="amount-calc">
                    <div>Vat(20%)</div>
                    <div>£ <%= (total_price - (delivery_charge || 0)).toFixed(2) %>
                    </div>
                </div>
                <div class="amount-calc">
                    <div>Booking Charge</div>
                    <div>£ <%= (delivery_charge || 0).toFixed(2) %>
                    </div>
                </div>
                <div class="totals">
                    <div>Net Amount</div>
                    <div>£ <%= Number(total_price || 0).toFixed(2) %>
                    </div>
                </div>
            </div>
            <% } else { %>
                <div class="totals-container"></div>
                <% } %>

                    <div class="footer"></div>
                    </div>
                    <% } %>
</body>

</html>