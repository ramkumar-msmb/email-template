<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            background-color: #f5f5f5;
            margin: 0;
            padding: 0;
        }

        .invoice-container {
            width: 21cm;
            height: 29.7cm;
            background-color: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
            position: relative;
        }

        .header {
            color: #222;
            border-bottom: 1px solid #D9D9D9;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 18px;
        }

        .header-left {
            display: flex;
            min-height: 60px;
            display: flex;
            align-items: center;
        }

        .header img {
            display: block;
            width: auto;
            height: auto;
            max-width: 100%;
        }

        .header-line{
            height: 1px;
            width: 20cm;
            padding: 0px 18px;
            margin: 0px 18px 10px 18px;
            background-color: #D9D9D9;
        }

        .clinic-details {
            text-align: right;
            line-height: 1.4;
        }

        .clinic-details p {
            font-size: 11px;
            margin: 2px 0;
        }
        .clinic-details strong {
            font-size: 15px;
            margin: 2px 0;
        }

        .prescription-info-container{
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
        }
        .prescription-info-container .px-meta-data-right p,
        .prescription-info-container .px-meta-data-left p{
            font-size: 12px;
            color: #444;
        }
        .prescription-info-container .px-meta-data-right p strong,
        .prescription-info-container .px-meta-data-left p strong{
            font-size: 12px;
            color: #222;
        }

        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
            padding-top: 2px;
            align-items: stretch;
            gap: 12px;
        }

        .details-box {
            width: 50%;
            display: flex;
            flex-direction: column;
            font-size: 12px;
        }

        .patient-details,
        .appointment-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }

        .details-heading {
            font-size: 10px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #222;
        }

        .patient-details p,
        .appointment-details p {
            display: flex;
            justify-content: space-between;
            gap: 5px;
        }

        .patient-details strong,
        .appointment-details strong,
        .age {
            text-align: left;
            font-weight: 400;
            font-size: 10px;
            color: #444;
        }

        .patient-details span,
        .appointment-details span,
        .age-value {
            flex-grow: 1;
            text-align: left;
            font-size: 10px;
            color: #222;
        }
        .age-value {
            margin-left: 5px;
        }

        .dob-age {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }

        .table-container {
            margin: 10px 18px;
            margin-top: 2px;
            overflow: hidden;
            border-radius: 10px;
            border: 0.5px solid #CBE3E3;
            /* min-height: 12cm; */
            max-height: 100%;
            position: relative;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            border: 0;
        }

        table thead,
        table tr {
            border: 0;
        }

        table th,
        table td {
            font-size: 10px;
            padding: 10px;
            text-align: left;
            vertical-align: top;
            border: 0;
            word-break: break-word;
        }

        table td {
            padding-bottom: 5px;
            padding-top: 5px;
        }
        table tr:first-child td {
            padding-top: 10px;
        }
        table tr:last-child td {
            padding-bottom: 10px;
        }

        table th {
            font-weight: 500;
            color: #444;
            height: 30px;
            font-size: 11px;
            border-bottom: 1px solid #d9d9d9;
        }

        table th:nth-child(1),
        table td:nth-child(1) {
            width: 10%;
        }

        table th:nth-child(2),
        table td:nth-child(2) {
            width: 45%;
        }

        table th:nth-child(3),
        table td:nth-child(3) {
            width: 25%;
        }

        table th:nth-child(4),
        table td:nth-child(4) {
            width: 20%;
        }

        .totals-container {
            padding: 15px 18px;
            background-color: white;
            line-height: 2.2;
            font-size: 9px;
        }

        .amount-calc {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            color: #444;
            font-size: 11px;
        }

        .totals {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            font-weight: 600;
            border-top: 1px solid #d9d9d9;
            padding-top: 10px;
            color: #222;
        }

        @media print {
            .invoice-container {
                page-break-after: always;
            }
        }
         .logo_url {
            height: 30px;
            object-fit: contain;
        }
        .watermark-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70%;
            opacity: 0.05;
            z-index: 0;
            filter: grayscale(1);
            pointer-events: none;
        }
    </style>
</head>

<body>
    <% 
    const items = prescription_items || [];
    let currentPage = 1;
    let itemsProcessed = 0;
    let availableHeight = 500.54; // Base available height for table
    
    // Calculate address height impact once before the loop
    const addressParts = [
        patient_details?.patient_address_line_1,
        patient_details?.patient_address_line_2,
        patient_details?.patient_city,
        patient_details?.patient_postal_code,
        patient_details?.patient_country
    ].filter(Boolean);

    const fullAddress = addressParts.join(', ');
    if (fullAddress.length > 72) {
        const dividedValue = Math.floor(fullAddress.length / 36);
        availableHeight -= (12 * dividedValue) + 10; // 10px is bottom margin of availableHeight
    }
    
    // Loop through pages using while loop for dynamic pagination
    while (itemsProcessed < items.length) {
    %>
    <div class="invoice-container">
        <!-- HEADER -->
        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                <img class="logo_url" src="<%= logo_url || 'https://dtl3fe7urqkwq.cloudfront.net/logo.png' %>" alt="SendScript">
            </div>
            <div class="clinic-details">
                <p><strong>INVOICE</strong></p>
                <p>Powered by SendScript</p>
            </div>
        </div>

        <div class="prescription-info-container">
            <div class="px-meta-data-right">
                <p>Invoice Number: <strong><%= invoice_id %></strong></p>
                <p>Invoice Date: <strong><% 
                    // Parse the ISO date string
                    const dobOriginal_invoice = new Date(invoice_date);
                    const dob_invoice = new Date(dobOriginal_invoice);
                    dob_invoice.setDate(dobOriginal_invoice.getDate());
                    const day_invoice = String(dob_invoice.getDate()).padStart(2, '0');
                    const month_invoice = String(dob_invoice.getMonth() + 1).padStart(2, '0'); // Month is 0-based
                    const year_invoice = dob_invoice.getFullYear();
                    const formattedDate_invoice = `${day_invoice}/${month_invoice}/${year_invoice}`;
                  %><%= formattedDate_invoice %></strong></p>
            </div>
        </div>
        <div class="header-line"></div>

        <!-- Patient Details and Pharmacy Details -->
        <div class="details-container">
            <!-- Patient Details -->
            <div class="details-box">
                <div class="details-heading">Patient Details</div>
                <div class="patient-details">
                    <p>
                        <strong>Full Name:</strong>
                        <span><%= patient_details.patient_title %> <%= patient_details.patient_first_name %> <%= patient_details.patient_sur_name %></span>
                    </p>
                    <p class="dob-age">
                        <strong>DOB:</strong>
                        <span><% 
                            // Parse the ISO date string
                            const dobOriginal = new Date(patient_details.patient_dob);
                            
                            // Create a new date object with the date incremented by 1
                            const dob = new Date(dobOriginal);
                            dob.setDate(dobOriginal.getDate());
                            
                            // Format as DD/MM/YYYY
                            const day = String(dob.getDate()).padStart(2, '0');
                            const month = String(dob.getMonth() + 1).padStart(2, '0'); // Month is 0-based
                            const year = dob.getFullYear();
                            
                            const formattedDate = `${day}/${month}/${year}`;
                          %>
                          <%= formattedDate %>
                            <span class="age" style="color: #444; font-weight: 500; margin-left: 10px;"> Age: </span>
                            <span class="age-value">
                                <%= patient_age %>
                            </span>
                        </span>
                    </p>
                    <p>
                        <strong>Address:</strong>
                        <span>
                            <%= [
                              patient_details?.patient_address_line_1,
                              patient_details?.patient_address_line_2,
                              patient_details?.patient_city,
                              patient_details?.patient_country,
                              patient_details?.patient_postal_code
                            ].filter(Boolean).join(', ') %>
                        </span>                          
                    </p>
                    <p>
                        <strong>Contact Number:</strong>
                        <span><%= patient_details.patient_country_code %> <%= patient_details.patient_mobile %></span>
                    </p>
                </div>
            </div>
        
            <!-- Pharmacy Details -->
            <% const label = entityLabel === 'Clinic' ? 'Clinic' : 'Pharmacy'; %>

            <div class="details-box">
                <div class="details-heading"><%= entityLabel %> Information</div>
                <div class="appointment-details">
                    <p>
                        <strong style="min-width: 59px;"><%= entityLabel %> Name:</strong>
                        <span><%= pharmacy.name %></span>
                    </p>
                    <p>
                        <strong style="min-width: 59px;"><%= entityLabel %> Address:</strong>
                        <span>
                            <%= [
                                pharmacy.address_line_1,
                                pharmacy.address_line_2,
                                pharmacy.address_line_3,
                                pharmacy.city,
                                pharmacy.county,
                                pharmacy.country
                            ].filter(Boolean).join(', ') %>
                        </span>
                    </p>
                    <p>
                        <strong style="min-width: 59px;">Email Address:</strong>
                        <span><%= pharmacy.email %></span>
                    </p>
                    <p>
                        <strong style="min-width: 59px;">Telephone:</strong>
                        <span><%= pharmacy.contact_number %></span>
                    </p>
                    <p>
                        <strong style="min-width: 59px;">Postal Code:</strong>
                        <span><%= pharmacy.postal_code %></span>
                    </p>
                </div>
            </div>
        </div>
        

        <!-- TABLE -->
        <img src="<%= logo_url || 'https://dtl3fe7urqkwq.cloudfront.net/logo.png' %>" class="watermark-container" alt="watermark-container">
        <div class="table-container" data-min-height="<%= Math.round(availableHeight) %>">
            <table>
                <thead>
                    <tr>
                        <th>SL No</th>
                        <th>Medicine</th>
                        <th>Quantity</th>
                        <th>Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <% let itemsInThisPage = 0; %>
                    <%
                        let currentHeight = 0;
                        let actualIsLastPage = false;
                    %>
                    <% for (let i = itemsProcessed; i < items.length; i++) { %>
                        <% 
                            // Estimate if this row will fit
                            const item = items[i];
                            let estimatedHeight = 44; // base height

                            // Estimate the height based on medicine name length
                            if (item.name && item.name.length > 197) {
                                estimatedHeight += 48;
                            } else if (item.name && item.name.length > 131) {
                                estimatedHeight += 24;
                            } else if (item.name && item.name.length > 65) {
                                estimatedHeight += 12;
                            }

                            // Estimate height for quantity + unit
                            const quantityUnit = `${item.quantity || ''} ${item.unit || ''}`.trim();
                            if (quantityUnit.length > 45) {
                                estimatedHeight += 96;
                            } else if (quantityUnit.length > 36) {
                                estimatedHeight += 48;
                            } else if (quantityUnit.length > 27) {
                                estimatedHeight += 24;
                            } else if (quantityUnit.length > 18) {
                                estimatedHeight += 12;
                            }

                            // Break if adding this row would exceed available height, but only if we already have at least one row in the current page
                            if (currentHeight + estimatedHeight > availableHeight && itemsInThisPage > 0) {
                                break;
                            }

                            currentHeight += estimatedHeight;
                        %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= item.name %></td>
                            <td>
                                <%= item.quantity %>
                                <%= item.unit %>
                            </td>
                            <td>£ <%= item.price %></td>
                        </tr>
                        <% 
                            itemsInThisPage++;
                            itemsProcessed++;
                            // Check if this is the last item overall
                            if (i === items.length - 1) {
                                actualIsLastPage = true;
                            }
                        %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- TOTALS SECTION - Only show on the last page -->
        <% if (actualIsLastPage) { %>
        <div class="totals-container">
            <div class="amount-calc">
                <div>Gross Amount</div>
                <div>£ <%= (total_price - (delivery_charge || 0)).toFixed(2) %></div>
            </div>
            <div class="amount-calc">
                <div>Delivery Charge</div>
                <div>£ <%= (delivery_charge || 0).toFixed(2) %></div>
            </div>
            <div class="totals">
                <div>Net Amount</div>
                <div>£ <%= Number(total_price || 0).toFixed(2) %></div>
            </div>
        </div>
        <% } else { %>
        <div class="totals-container"></div>
        <% } %>
    </div>
    <% 
        currentPage++;
    } %>
    <script>
        document.querySelectorAll('.table-container').forEach(container => {
            const minHeight = container.getAttribute('data-min-height');
            if (minHeight) {
                container.style.minHeight = minHeight + 'px';
            }
        });
    </script>
</body>

</html>