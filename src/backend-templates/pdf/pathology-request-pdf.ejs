<!DOCTYPE html>
<html lang='en'>

<head>
    <meta charset='UTF-8'>
    <title>Pathology Request Form</title>
    <style>
        /* @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap'); */

        @page {
            size: A4;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            color: #111827;
            background-color: #F3F4F6;
            -webkit-font-smoothing: antialiased;
        }

        .page-container {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .page {
            background-color: #FFFFFF;
            width: 210mm;
            height: 297mm;
            position: relative;
            display: flex;
            flex-direction: column;
            page-break-after: always;
            box-shadow: none;
            overflow: hidden;
            /* padding: 16px 18px; */
        }

        .header {
            color: #222;
            border-bottom: 1px solid #D9D9D9;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 18px;
        }

        .header-left {
            display: flex;
            min-height: 60px;
            display: flex;
            align-items: center;
        }

        .header img {
            height: auto;
            width: auto;
            max-width: 100%;
            max-height: 60px;
        }
        .clinic-details {
            text-align: right;
            line-height: 1.4;
        }

        .clinic-details p {
            font-size: 11px;
            margin: 2px 0;
        }
        .clinic-details strong {
            font-size: 15px;
            margin: 2px 0;
        }
         .prescription-info-container{
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
        }
        .prescription-info-container .px-meta-data-right p,
        .prescription-info-container .px-meta-data-left p{
            font-size: 14px;
            color: #444;
        }
        .prescription-info-container .px-meta-data-right p strong,
        .prescription-info-container .px-meta-data-left p strong{
            font-size: 14px;
            color: #222;
        }

        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 10px 18px;
            padding-top: 2px;
            align-items: stretch;
            gap: 12px;
        }

        .details-box {
            width: 50%;
            display: flex;
            flex-direction: column;
            font-size: 12px;
        }
        .details-box .comments{
            font-size: 12px;
            font-weight: 400;
            color: #444;
        }

        .patient-details,
        .appointment-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }

        .patient-details,
        .appointment-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
            border-radius: 6px;
            border: 0.5px solid #D9D9D9;
            flex-grow: 1;
        }


        .details-heading {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #222;
        }



        .patient-details p,
        .appointment-details p {
            display: flex;
            justify-content: space-between;
            gap: 5px;
        }


        .patient-details strong,
        .appointment-details strong,
        .age {
            text-align: left;
            font-weight: 400;
            font-size: 12px;
            color: #444;
            min-width: 80px !important;
        }


        .patient-details span,
        .appointment-details span,
        .age-value {
            flex-grow: 1;
            text-align: left;
            font-size: 12px;
            color: #222;
        }
        .age-value {
        margin-left: 5px;
        }

        .dob-age {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }
        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            padding: 15px 18px;
            border-bottom: 1px solid #D9D9D9;
        }

        .logo-box {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-img {
            max-height: 28px;
            object-fit: contain;
        }

        .logo-text {
            font-size: 26px;
            font-weight: 600;
            color: #111827;
            letter-spacing: -0.5px;
        }

        .form-title {
            font-size: 18px;
            font-weight: 700;
            color: #1F1F1F;
            text-transform: uppercase;
        }

        .meta-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-inline:18px;
            padding-bottom: 8px;
            font-size: 14px;
        }

        .meta-info {
            display: flex;
            flex-direction: column;
        }

        .meta-row {
            display: flex;
            gap: 8px;
        }

        .meta-label {
            color: #444444;
        }

        .meta-value {
            font-weight: 600;
            color: #222222;
        }

        .lab-provider {
            text-align: right;
            font-size: 10px;
            color: #444444;
            align-self: self-start;
        }

        .lab-provider strong {
            color: #111827;
            font-weight: 700;
        }

        .info-cards-section {
            display: flex;
            gap: 10px;
            padding-inline:18px;
        }

        .info-card-col {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .card-title {
            font-size: 13px;
            font-weight: 600;
            color: #222222;
            margin-bottom: 10px;
        }

        .info-card {
            border: 1px solid #E5E7EB;
            border-radius: 10px;
            padding: 12px;
            font-size: 9px;
            min-height: 110px;
            flex: 1;
        }

        /* Patient grid */
        .patient-grid {
            display: grid;
            grid-template-columns: 60px 1fr 75px 1fr;
            align-items: center;
        }

        .patient-grid .full-span {
            grid-column: 2 / -1;
        }

        .grid-label {
            color: #444444;
        }

        .grid-value {
            font-weight: 600;
            color: #222222;
        }

        /* Clinic grid */
        .clinic-grid {
            display: grid;
            grid-template-columns: 80px 1fr;
            gap: 10px 2px;
            align-items: start;
        }

        /* Main content layout */
        .main-content {
            display: flex;
            gap: 20px;
            margin-top: 2px;
            flex: 1;
            padding-inline:18px;
            /* allow growing */
        }

        .tests-column {
            flex: 1;
            border: 1px solid #E5E7EB;
            border-radius: 12px;
            padding: 10px 12px;
            position: relative;
            height: fit-content;
            overflow: hidden;
        }

        .tests-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            position: relative;
            z-index: 1;
        }

        .tests-table th {
            text-align: left;
            color: #444444;
            font-weight: 600;
            padding-bottom: 10px;
            border-bottom: 1px solid #E5E7EB;
            text-transform: capitalize;
        }

        .tests-table td {
            padding: 10px 0;
            color: #242424;
        }

        .tests-table td.qty-code {
            color: #242424;
        }

        .clinical-details-column {
            width: 250px;
            display: flex;
            flex-direction: column;
        }

        .clinical-card {
            border: 1px solid #CBE3E3;
            border-radius: 12px;
            padding: 12px;
            font-size: 13px;
            color: #444444;
            line-height: 1.6;
        }

        .clinical-card-title {
            font-weight: 600;
            color: #222222;
            margin-bottom: 8px;
        }

        .checkbox-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            font-size: 13px;
            color: #444444;
            margin-top: 12px;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .checkbox-icon {
            width: 14px;
            height: 14px;
            border: 1.5px solid #444444;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .checkbox-icon svg {
            width: 14px;
            height: 14px;
            color: transparent;
        }

        .checkbox-icon.checked {
            border-color: #444444;
        }

        .checkbox-icon.checked svg {
            color: #444444;
        }

        .clinical-text-block {
            font-size: 13px;
            line-height: 1.6;
            color: #444444;
            margin-top: 12px;
        }

        .clinical-text-block strong {
            color: #222222;
            font-weight: 600;
        }

        /* Footer / Prescribed By section */
        .page-bottom-section {
            margin-top: auto;
            padding-top: 25px;
            padding-inline:18px;
            padding-bottom: 18px;
        }
        .header-line{
            height: 1px;
            width: 20cm;
            padding: 0px 18px;
            margin: 0px 18px 10px 18px;
            background-color: #D9D9D9;
        }
        .prescribed-title {
            font-size: 13px;
            font-weight: 600;
            color: #222222;
            margin-bottom: 8px;
        }

        .prescriber-info {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #D9D9D9;
        }

        .prescriber-col {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .prescriber-label {
            color: #222222;
        }

        .prescriber-value {
            font-weight: 700;
            color: #111827;
        }

        .signature-area {
            display: flex;
            gap: 20px;
            margin-top: 12px;
            align-items: center;
        }

        .qr-code-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .qr-code {
            width: 45px;
            height: 45px;
            object-fit: contain;
        }

        .qr-text {
            font-size: 6px;
            font-weight: 700;
            color: #222222;
        }

        .signature-details {
            font-size: 11px;
            color: #444444;
            line-height: 1.8;
            flex: 1;
        }

        .signature-details strong {
            color: #222222;
            font-weight: 600;
        }

        .signature-details a {
            color: #222222;
            text-decoration: none;
            font-weight: 600;
        }

        /* Watermark in tests table */
        .table-watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 320px;
            opacity: 0.04;
            z-index: 0;
            pointer-events: none;
            filter: grayscale(1);
        }
    </style>
</head>

<body>
    <div class='page-container'>
        <% const formatDate=(dateStr)=> {
            if (!dateStr || dateStr.startsWith('{')) return dateStr;
            try {
            const d = new Date(dateStr);
            if (isNaN(d.getTime())) return dateStr;
            return d.toLocaleDateString('en-GB');
            } catch {
            return dateStr;
            }
            };

            let testsList = typeof tests !== 'undefined' ? (Array.isArray(tests) ? tests : [tests]) : [];

            // Available height for items table
            const AVAILABLE_HEIGHT_FIRST_PAGE = 550;
            const AVAILABLE_HEIGHT_OTHER_PAGES = 650;

            let itemsProcessed = 0;
            let pageIndex = 0;
            const totalItems = testsList.length;
            %>

            <% while (itemsProcessed < totalItems || pageIndex===0) { %>
                <% const isFirstPage=pageIndex===0; const availableHeight=isFirstPage ? AVAILABLE_HEIGHT_FIRST_PAGE :
                    AVAILABLE_HEIGHT_OTHER_PAGES; let currentHeight=0; let itemsInThisPage=0; let isLastPage=false; %>
                    <div class='page'>
                        <div class="header">
                            <div class="header-left">
                                <img class="logo_url" src="<%= logo_url || 'https://dtl3fe7urqkwq.cloudfront.net/logo.png' %>" alt="SendScript">
                            </div>
                        
                            <div class="clinic-details">
                                <p><strong>PATHOLOGY REQUEST FORM</strong></p>
                                <p>Powered by SendScript</p>
                            </div>
                        </div>
                        <div class="prescription-info-container">
                            <div class="px-meta-data-right">
                                <p>Order Number: <strong> <%= typeof order_number !=='undefined' ? order_number : '{order_number}' %> </strong></p>
                                <p>Date: <strong> <%= typeof date !=='undefined' ? formatDate(date) : '{date}' %> </strong></p>
                            </div>
                            <div class="px-meta-data-left">
                                <p>Lab Provider Name: <strong><%= typeof lab_provider_name !=='undefined' ? lab_provider_name : '{lab_provider_name}' %> </strong></p>
                            </div>
                        </div>
                         <div class="header-line"></div>
                        <% if (isFirstPage || testsList.length===0) { %>
                            <div class="details-container">
                                <div class="details-box">
                                    <div class="details-heading">Patient Details</div>
                                    <div class="patient-details">
                                        <p><strong>Full Name:</strong> <span>
                                                <%= typeof patient_name !=='undefined' ? patient_name : '{patient_name}' %>
                                            </span>
                                        </p>
                                        <p class="dob-age">
                                            <strong>DOB:</strong> <span>
                                                <%= typeof patient_dob !=='undefined' ? formatDate(patient_dob) : '{dob}' %>
                                                    (<%= typeof patient_age !=='undefined' ? patient_age : '{age}' %>)
                                                    <span class="age" style="color: #444; font-weight: 500; margin-left: 10px;"> Gender:
                                                    </span>
                                                    <span class="age-value">
                                                        <%= typeof patient_gender !=='undefined' ? patient_gender : '{gender}' %>
                                                    </span>
                                            </span>
                                        </p>
                                        <p><strong>Contact:</strong> <span>
                                            <%= typeof patient_mobile !== 'undefined' ? `${patient_country_code || ''} ${patient_mobile}` : '{mobile}' %>
                                            </span></p>
                                        <p><strong >Address:</strong>
                                            <span>
                                                <%= typeof patient_address !=='undefined' ? patient_address : '{address}' %>
                                            </span>
                                        </p>
                                        
                                    </div>
                                </div>

                                <div class="details-box">
                                    <div class="details-heading">Clinic Information</div>
                                    <div class="appointment-details">
                                        <p><strong style="min-width: 59px;">Clinic Name:</strong>
                                            <span>
                                                <%= typeof clinic_name !=='undefined' ? clinic_name : '{clinic_name}' %>
                                            </span>
                                        </p>
                                        <p><strong style="min-width: 59px;">Email:</strong> 
                                            <span>
                                                <%= typeof clinic_email !=='undefined' ? clinic_email : '{clinic_email}' %>
                                            </span>
                                        </p>
                                        <p><strong style="min-width: 59px;">Telephone:</strong> 
                                            <span>
                                                <%= typeof clinic_telephone !=='undefined' ? clinic_telephone
                                                : '{clinic_telephone}' %>
                                            </span>
                                        </p>
                                        <p><strong style="min-width: 59px;">Clinic Address:</strong> 
                                            <span>
                                                <%= typeof clinic_address !=='undefined' ? clinic_address
                                                : '{clinic_address}' %>
                                            </span>
                                        </p>
                                        
                                    </div>
                                </div>
                            </div>
                            <% } %>
                            <% if (typeof show_watermark==='undefined' || show_watermark) { %>
                                            <img src="<%= typeof logo_url !== 'undefined' && logo_url ? logo_url : 'https://d2pznqasld4zpy.cloudfront.net/logo.png' %>"
                                                class="table-watermark" alt="Watermark">
                                            <% } %>
                                <section class='main-content'>
                                    <div class='tests-column'>
                                        
                                                <table class='tests-table'>
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 50px;">SL No</th>
                                                            <th>Test/Profile</th>
                                                            <th style="width: 65px;">Code</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% if (testsList.length> 0) {
                                                            for (let i = itemsProcessed; i < totalItems; i++) { const
                                                                test=testsList[i]; let estimatedHeight=42; if
                                                                (currentHeight + estimatedHeight> availableHeight &&
                                                                itemsInThisPage > 0) {
                                                                break;
                                                                }
                                                                currentHeight += estimatedHeight;
                                                                itemsInThisPage++;
                                                                itemsProcessed++;
                                                                if (i === totalItems - 1) isLastPage = true;
                                                                %>
                                                                <tr>
                                                                    <td>
                                                                        <%= i + 1 %>
                                                                    </td>
                                                                    <td>
                                                                        <%= test.service_name || test.test_name || '-'
                                                                            %>
                                                                    </td>
                                                                    <td class="qty-code">
                                                                        <%= test.code || '-' %>
                                                                    </td>
                                                                </tr>
                                                                <% } } else { isLastPage=true; itemsProcessed=0; } %>
                                                    </tbody>
                                                </table>
                                    </div>

                                    <% if (isFirstPage || testsList.length===0) { %>
                                        <div class='clinical-details-column'>
                                            <div class='card-title'>Clinical Details</div>

                                            <div class='clinical-card'>
                                                <div class='clinical-card-title'>Clinical Information</div>
                                                <p>
                                                    <%= typeof clinical_information !=='undefined' ?
                                                        clinical_information : '---' %>
                                                </p>
                                            </div>

                                            <div class='checkbox-list'>
                                                <% 
                                                const excludedKeys = ['clinical_information', 'ethnic_origin', 'drug_therapy', 'notes'];
                                                const details = typeof clinical_details !== 'undefined' ? clinical_details : {};
                                                
                                                Object.keys(details).forEach(function(key) {
                                                    if (excludedKeys.includes(key)) return;
                                                    
                                                    const isChecked = !!details[key];
                                                    let label = key;
                                                    if (key.toLowerCase() === 'hrt') {
                                                        label = 'HRT';
                                                    } else {
                                                        label = key.split('_').map(function(word) {
                                                            return word.charAt(0).toUpperCase() + word.slice(1);
                                                        }).join(' ');
                                                    }
                                                %>
                                                    <div class='checkbox-item'>
                                                        <div class='checkbox-icon <%= isChecked ? "checked" : "" %>'>
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                                stroke-width="3" stroke-linecap="round"
                                                                stroke-linejoin="round">
                                                                <polyline points="20 6 9 17 4 12"></polyline>
                                                            </svg>
                                                        </div>
                                                        <span><%= label %></span>
                                                    </div>
                                                <% }); %>
                                            </div>

                                            <div class='clinical-text-block'>
                                                <strong>Ethnic origin:</strong>
                                                <%= typeof ethnic_origin !=='undefined' ? ethnic_origin : '---' %>
                                            </div>

                                            <div class='clinical-text-block'>
                                                <strong>Drug Therapy:</strong>
                                                <%= typeof drug_therapy !=='undefined' ? drug_therapy : '---' %>
                                            </div>
                                        </div>

                                        <% } else { %>
                                            <div class='clinical-details-column'></div>
                                            <% } %>
                                </section>

                                <div class="page-bottom-section">
                                    <div class="prescribed-title">Prescribed By</div>
                                    <div class="prescriber-info">
                                        <div class="prescriber-col" style="max-width: 300px;">
                                            <span class="prescriber-label">Name:</span>
                                            <span class="prescriber-value">
                                                <%= typeof prescriber_name !=='undefined' ? prescriber_name
                                                    : '{prescriber_name}' %>
                                            </span>
                                        </div>
                                        <div class="prescriber-col"
                                            style="flex: 1.5; padding-left: 15px; max-width: 130px;">
                                            <span class="prescriber-label">Registration No:</span>
                                            <span class="prescriber-value">
                                                <%= typeof prescriber_registration_no !=='undefined' ?
                                                    prescriber_registration_no : '{registration_no}' %>
                                            </span>
                                        </div>
                                        <div class="prescriber-col" style="flex: 1.5; padding-left: 15px;">
                                            <span class="prescriber-label">Qualification:</span>
                                            <span class="prescriber-value">
                                                <%= typeof prescriber_qualification !=='undefined' ?
                                                    prescriber_qualification : '{qualification}' %>
                                            </span>
                                        </div>
                                    </div>

                                    <div class="signature-area">
                                        <div class="signature-details">
                                            <strong>This request form has been electronically signed using an Advanced Electronic Signature</strong>
                                            <p>E-signature: <strong>
                                                    <%= typeof e_signature_tracker !=='undefined' ? e_signature_tracker
                                                        : '{e_signature_tracker}' %>
                                                </strong></p>
                                            <p>Time of signature: <strong>
                                                    <%= typeof signature_time !=='undefined' ? signature_time
                                                        : '{signature_time}' %>
                                                </strong></p>
                                        </div>
                                    </div>
                                </div>

                    </div>
                    <% pageIndex++; %>
                        <% if (itemsProcessed>= totalItems && pageIndex > 0) break; %>
                            <% } %>
    </div>
</body>

</html>