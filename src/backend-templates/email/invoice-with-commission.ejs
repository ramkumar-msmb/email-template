<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f9f9f9;
        }

        .invoice-container {
            height: 29.7cm;
            width: 21cm;
            background-color: white;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
        }

        .header {
            background-color: #1b3f6d;
            color: white;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-left {
            display: flex;
            flex-direction: column;
        }

        .header-left img {
            margin-bottom: 70px;
        }

        .header-left p {
            font-size: 16px;
            font-weight: 600;
            margin-top: 10px;
        }

        .header-right {
            text-align: right;
            line-height: 1.7;
        }

        .header-right p {
            font-size: 12px;
            margin: 2px 0;
        }

        .header-right p:first-child {
            font-size: 14px;
            font-weight: 600;
        }

        .table-container {
            margin: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th,
        table td {
            padding: 12px;
            border: 1px solid #ddd;
            font-size: 14px;
            font-weight: 300;
        }

        table th {
            font-weight: bold;
            background-color: #1b3f6d;
            color: #fff;
            text-align: center;
        }

        table td {
            text-align: left;
        }

        table td:first-child,
        table td:nth-child(3),
        table td:nth-child(4) {
            text-align: center;
        }

        .totals-container {
            padding: 20px;
            background-color: white;
            flex-grow: 1;
            line-height: 2.2;
        }

        .amount-calc {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            font-size: 14px;
        }

        .totals {
            display: flex;
            justify-content: space-between;
            font-size: 16px;
            font-weight: bold;
            border-top: 1px solid #ccc;
            padding-top: 10px;
        }

        .fixed-bottom {
            position: relative;
            margin-top: auto;
            width: 100%;
        }

        .delivery-type {
            background-color: #e8ecf0;
            padding: 8px;
            font-size: 12px;
            font-weight: 400;
        }

        .footer {
            background-color: #1b3f6d;
            height: 23px;
            color: #fff;
            text-align: center;
            font-size: 12px;
            line-height: 20px;
        }

        .details-container {
            display: flex;
            justify-content: space-between;
            padding: 15px 20px;
            margin-top: 10px;
        }

        .details-box {
            width: 48%;
            display: flex;
            flex-direction: column;
        }

        .patient-details, .invoice-details {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 15px;
            background-color: #F3F9FF;
            border-radius: 5px;
            flex-grow: 1;
            font-size: 12px;
        }

        .details-heading {
            font-size: 13px;
            font-weight: 400;
            margin-bottom: 5px;
            color: #242424;
            padding-left: 10px;
            padding-top: 5px;
        }

        .patient-details p, .invoice-details p {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin: 5px 0;
        }

        .patient-details strong, .invoice-details strong {
            min-width: 140px;
            text-align: left;
            font-weight: 500;
        }

        .patient-details span, .invoice-details span {
            flex-grow: 1;
            text-align: left;
            color: #1B3F6D;
        }

        @media print {
            .invoice-container {
                page-break-after: always;
            }
        }
    </style>
</head>

<body>
    <% 
    const items = scans || [];
    // Calculate total pages needed
    const itemsPerPage = 10;
    const totalPages = Math.ceil(items.length / itemsPerPage);
    
    // Loop through pages
    for (let page = 0; page < totalPages; page++) {
        const startIndex = page * itemsPerPage;
        const endIndex = Math.min(startIndex + itemsPerPage, items.length);
        const pageItems = items.slice(startIndex, endIndex);
        const isLastPage = page === totalPages - 1;
    %>
    <div class="invoice-container">
        <!-- HEADER -->
        <div class="header">
            <div class="header-left">
                <img src="https://d2pznqasld4zpy.cloudfront.net/common/WebLogo.svg" alt="SendScript">
                <p>Invoice</p>
            </div>
            <div class="header-right">
                <p><%= patient.site_name %></p>
                <p>
                    <%= [
                      patient.site_address_line_1,
                      patient.site_address_line_2,
                      patient.site_address_line_3,
                      patient.site_city,
                      patient.site_county,
                      patient.site_country
                    ].filter(Boolean).join(', ') %>
                </p>
                <p><%= patient.site_postal_code %></p>
                <p>Tel: <%= patient.site_contact_number %></p>
                <p>Email: <%= patient.site_email %></p>
            </div>
        </div>

        <div class="details-container">
            <div class="details-box">
                <div class="details-heading">Patient Details</div>
                <div class="patient-details">
                    <p>
                        <strong>Full Name:</strong>
                        <span><%= patient.patient_name %></span>
                    </p>
                    <p>
                        <strong>Date Of Birth:</strong>
                        <span>
                          <% 
                            const dob = new Date(patient.dob);
                            const formattedDate = `${String(dob.getDate()).padStart(2,'0')}/${String(dob.getMonth()+1).padStart(2,'0')}/${dob.getFullYear()}`;
                          %>
                          <%= formattedDate %>
                        </span>
                        <span>
                            <span style="color:#000;font-weight:500;margin-left:10px;">Age:</span>
                            <span><%= patient.patient_age %></span>
                        </span>
                    </p>
                    <p style="line-height: 16px;">
                        <strong>Address:</strong>
                        <span>
                          <%= (
                            [patient?.address_line_1, patient?.address_line_2, patient?.city, patient?.country, patient?.postal_code]
                              .filter(v => v && v.trim())
                              .join(', ')
                          ) || '-' %>
                        </span>
                      </p>
                      
                      <p>
                        <strong>Contact Number:</strong>
                        <span><%= patient?.country_code %> <%= patient?.mobile?.trim() || '-' %></span>
                    </p>
                </div>
            </div>

            <div class="details-box">
                <div class="details-heading">Invoice Details</div>
                <div class="invoice-details">
                    <p>
                        <strong>Invoice Number:</strong>
                        <span><%= invoice_number %></span>
                    </p>
                    <p>
                        <strong>Invoice Date:</strong>
                        <span>
                          <% 
                            const invDate = new Date(invoice_date);
                            const formattedInvDate = `${String(invDate.getDate()).padStart(2,'0')}/${String(invDate.getMonth()+1).padStart(2,'0')}/${invDate.getFullYear()}`;
                          %>
                          <%= formattedInvDate %>
                        </span>
                    </p>
                </div>
            </div>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>SL No</th>
                        <th>Scan</th>
                        <th>Total Amounts</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let i = 0; i < pageItems.length; i++) { 
                        const item = pageItems[i];
                        const itemNumber = startIndex + i + 1;
                    %>
                    <tr>
                        <td><%= itemNumber %></td>
                        <td><%= item.scan_name %><%= item.body_part ? ' - ' + item.body_part : '' %></td>
                        <td style="text-align: right; align-items: right;">£ <%= item.out_patient_price %></td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (isLastPage) { %>
        <div class="totals-container">
            <div class="amount-calc">
                <div>Gross Amount</div>
                <div>£ <%= Number(grossAmount).toFixed(2) %></div>
            </div>
            <div class="amount-calc">
                <div>Discount</div>
                <div>( - ) £ <%= Number(commissionValue || 0).toFixed(2) %></div>
            </div>
            <div class="totals">
                <div>Net Amount</div>
                <div>£ <%= Number(netAmount || 0).toFixed(2) %></div>
            </div>
        </div>
        <% } else { %>
        <div class="totals-container"></div>
        <% } %>

        <div class="footer"></div>
    </div>
    <% } %>
</body>

</html>